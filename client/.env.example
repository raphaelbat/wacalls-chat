# Base URL of the WaCalls backend API.
# Leave empty to use the Vite dev proxy (dev) or same-origin (when the Go
# server serves the built SPA). Set to an absolute URL when the frontend
# is hosted separately from the backend.
#
# Examples:
#   VITE_API_BASE_URL=
#   VITE_API_BASE_URL=http://localhost:3001
#   VITE_API_BASE_URL=https://api.meudominio.com
VITE_API_BASE_URL=